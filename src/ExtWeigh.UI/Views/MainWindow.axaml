<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="using:Avalonia.Controls.Primitives"
        xmlns:vm="using:ExtWeigh.UI.ViewModels"
        x:Class="ExtWeigh.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ExtWeigh — Chrome 拡張オーバーヘッド計測"
        Icon="avares://ExtWeigh.UI/Assets/app.ico"
        Width="1150" Height="800"
        MinWidth="960" MinHeight="640"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="32"
        WindowStartupLocation="CenterScreen">

  <Panel>
    <!--  ウィンドウ背景：アクリルブラー（Lhamiel 準拠）  -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
            BackgroundSource="Digger"
            MaterialOpacity="0.85"
            TintColor="{DynamicResource Color.Window}"
            TintOpacity="0.9" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Grid>
      <!--  ═══ サイドバー + コンテンツ ═══  -->
      <TabControl Margin="16,36,16,16" Classes="sidebar" SelectedIndex="{Binding SelectedTabIndex}">

        <!--  ━━━ 計測タブ ━━━  -->
        <TabItem Header="計測">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,0">
              <TextBlock Classes="h1" Text="計測" />

              <primitives:HeaderedContentControl Header="計測対象の拡張機能（MV3 / 複数選択可）">
                <StackPanel Spacing="8">
                  <ItemsControl ItemsSource="{Binding Measure.Extensions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ExtensionItemViewModel">
                        <Border Classes="card" Padding="10" Margin="0,0,0,4">
                          <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Summary}" Classes="label" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Path}" Classes="label" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Padding="8,4" Margin="8,0,0,0"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Measure.RemoveExtensionCommand}"
                                    CommandParameter="{Binding}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="＋ 拡張フォルダを追加..." HorizontalAlignment="Left"
                          Command="{Binding Measure.AddExtensionsCommand}" />
                  <TextBlock Text="{Binding Measure.ExtensionSummary}" TextWrapping="Wrap" Classes="label" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="再現したい使い方（計測シナリオ）">
                <StackPanel Spacing="10">
                  <TextBlock TextWrapping="Wrap"
                             Text="重いと感じるページと、そのときの使い方を選びます。ExtWeigh は同じ操作を拡張の条件ごとに再生して、差を比べます。" />

                  <Border Classes="scenario-guide">
                    <Grid ColumnDefinitions="*,*,*">
                      <StackPanel Spacing="3">
                        <TextBlock Classes="scenario-guide-title" Text="1. ページを決める" />
                        <TextBlock Classes="label" TextWrapping="Wrap"
                                   Text="普段重いと感じる、ログイン不要のページURLにします。" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="12,0" Spacing="3">
                        <TextBlock Classes="scenario-guide-title" Text="2. 実行内容を見る" />
                        <TextBlock Classes="label" TextWrapping="Wrap"
                                   Text="下の「この条件で行うこと」が毎回同じように再生されます。" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Margin="12,0,0,0" Spacing="3">
                        <TextBlock Classes="scenario-guide-title" Text="3. まずは短く試す" />
                        <TextBlock Classes="label" TextWrapping="Wrap"
                                   Text="30秒・1回で確認し、判断するときは繰り返しを3回以上にします。" />
                      </StackPanel>
                    </Grid>
                  </Border>

                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="拡張フォルダを追加すると対象サイトから候補を作成します。候補のURLは、普段使うページへ自由に置き換えられます。" />

                  <ItemsControl ItemsSource="{Binding Measure.Scenarios}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ScenarioItemViewModel">
                        <Border Classes="scenario-card" Margin="0,0,0,8">
                          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                              <CheckBox Grid.Column="0" Content="この使い方を計測" IsChecked="{Binding Enabled}" />
                              <TextBlock Grid.Column="1" Classes="scenario-kind" Text="{Binding ScenarioTypeLabel}" />
                              <TextBlock Grid.Column="2" Classes="scenario-source" Text="{Binding SourceDescription}"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Button Grid.Row="0" Grid.Column="1" Content="削除" Padding="10,5"
                                    ToolTip.Tip="この使い方を削除します"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Measure.RemoveScenarioCommand}"
                                    CommandParameter="{Binding}" />

                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="190,*,110" ColumnSpacing="10" Margin="0,10,0,0">
                              <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="結果に表示する名前" />
                                <TextBox Text="{Binding Name}" PlaceholderText="例: YouTubeを読み進める" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Classes="label" Text="拡張が動くページのURL" />
                                <TextBox Text="{Binding Url}" PlaceholderText="https://example.com/" />
                              </StackPanel>
                              <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="計測時間（目安）" />
                                <NumericUpDown Value="{Binding DurationSec}"
                                               Minimum="10" Maximum="600" Increment="5" FormatString="0" />
                              </StackPanel>
                            </Grid>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="scenario-preview" Margin="0,10,0,0">
                              <StackPanel Spacing="3">
                                <TextBlock Classes="label" Text="この条件で行うこと" />
                                <TextBlock Text="{Binding ExecutionDescription}" TextWrapping="Wrap" />
                                <TextBlock Classes="label" Text="{Binding EstimatedDurationDescription}" />
                              </StackPanel>
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="＋ 普段使うページを追加" HorizontalAlignment="Left"
                            ToolTip.Tip="ページを開いて、待機とスクロールを行う計測を追加します"
                            Command="{Binding Measure.AddScenarioCommand}" />
                    <TextBlock Text="{Binding Measure.ScenarioSummary}" Classes="label" TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="オプション">
                <StackPanel Spacing="8">
                  <StackPanel Orientation="Horizontal" Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                ToolTip.Tip="同じ計測を複数回繰り返して中央値±σで評価します。サイトの状態やネットワークの揺らぎを吸収するため 3 回以上を推奨します。">
                      <TextBlock Classes="label" Text="繰り返し回数" />
                      <NumericUpDown Value="{Binding Measure.RepeatCount}"
                                     Minimum="1" Maximum="9" Increment="1" FormatString="0" Width="100" />
                    </StackPanel>
                    <CheckBox Content="Chrome trace を取得" IsChecked="{Binding Measure.EnableTracing}"
                              ToolTip.Tip="Chrome のフルトレース (trace.json) も保存します。Perfetto / chrome://tracing で詳細分析したいときに ON にします（ファイルサイズは大きめ）。" />
                    <CheckBox Content="ブラウザを表示（既定は画面外で実行）" IsChecked="{Binding Measure.ShowBrowser}"
                              ToolTip.Tip="OFF のままなら Chrome は画面外で動くので作業の邪魔をしません。拡張の挙動を目視確認したいときだけ ON にします。" />
                  </StackPanel>
                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="💡 複数拡張では、全OFF・全ON・1つずつOFFの条件を計測します。計測中は PC で重い作業をしないと精度が上がります。" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
                <Button Classes="accent" Content="▶ 計測開始" Command="{Binding Measure.StartMeasurementCommand}" />
                <Button Content="⏹ 停止" Command="{Binding Measure.StopMeasurementCommand}" />
                <TextBlock Text="{Binding Measure.StatusText}" Classes="label" VerticalAlignment="Center" />
              </StackPanel>

              <ProgressBar Minimum="0" Maximum="100" Value="{Binding Measure.ProgressPercent}"
                           Height="8" Margin="0,0,0,12" />

              <primitives:HeaderedContentControl Header="ログ">
                <ScrollViewer x:Name="LogScroll" Height="200">
                  <ItemsControl ItemsSource="{Binding Measure.LogLines}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}" FontFamily="Consolas,Cascadia Mono,monospace"
                                   FontSize="12" TextWrapping="Wrap" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </primitives:HeaderedContentControl>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!--  ━━━ 結果タブ ━━━  -->
        <TabItem Header="結果">
          <Grid ColumnDefinitions="280,*" RowDefinitions="Auto,Auto,*" Margin="8,0">

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="h1" Text="結果" />

            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="6" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="🔄 更新" Command="{Binding Results.RefreshCommand}" />
                <Button Content="🌐 レポートを開く" Command="{Binding Results.OpenReportCommand}"
                        ToolTip.Tip="ソート可能なテーブルと Top 30 hot functions を含む HTML レポートをブラウザで開きます。" />
                <Button Content="📁 フォルダを開く" Command="{Binding Results.OpenFolderCommand}"
                        ToolTip.Tip="cpuprofile / trace.json などの生データが入った出力フォルダをエクスプローラーで開きます。" />
                <TextBlock Text="{Binding Results.HeaderText}" Classes="label" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Classes="label" TextWrapping="Wrap"
                         Text="読み方: 全体Δ = 全ON − 全OFF。拡張別寄与 = 全ON − その拡張だけOFF（プラスの赤字 = その拡張が重くしている）／ SIGNIF = 有意差 ／ NOISE = 誤差内" />
            </StackPanel>

            <Border Grid.Row="2" Grid.Column="0" Classes="card" Padding="6" Margin="0,0,0,12">
              <ListBox Background="Transparent"
                       ItemsSource="{Binding Results.Runs}"
                       SelectedItem="{Binding Results.SelectedRun}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RunListItemViewModel">
                    <StackPanel Margin="0,2">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding GeneratedAt}" Classes="label" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <ScrollViewer Grid.Row="2" Grid.Column="1" Margin="12,0,0,0">
              <ItemsControl ItemsSource="{Binding Results.ScenarioResults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ScenarioResultViewModel">
                    <Border Classes="card" Margin="0,0,0,12">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock Text="{Binding Url}" Classes="label" />

                        <!-- 全ONと1つ抜きの差から求めた拡張別寄与 -->
                        <TextBlock Text="拡張別の条件付き寄与（全ON − この拡張だけOFF）"
                                   FontWeight="SemiBold" Margin="0,8,0,0" />
                        <Grid ColumnDefinitions="*,100,100,100,70,70" Margin="0,4,0,0">
                          <TextBlock Grid.Column="0" Classes="label" Text="拡張" />
                          <TextBlock Grid.Column="1" Classes="label" Text="CPU寄与" TextAlignment="Right" />
                          <TextBlock Grid.Column="2" Classes="label" Text="Long Tasks" TextAlignment="Right" />
                          <TextBlock Grid.Column="3" Classes="label" Text="ヒープ" TextAlignment="Right" />
                          <TextBlock Grid.Column="4" Classes="label" Text="評価" TextAlignment="Right" />
                          <TextBlock Grid.Column="5" Classes="label" Text="判定" TextAlignment="Right" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ExtensionImpacts}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExtensionImpactRowViewModel">
                              <Grid ColumnDefinitions="*,100,100,100,70,70" Margin="0,1">
                                <TextBlock Grid.Column="0" Text="{Binding ExtensionName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding CpuDelta}" TextAlignment="Right"
                                           Foreground="{DynamicResource Brush.Danger}" IsVisible="{Binding IsIncrease}" />
                                <TextBlock Grid.Column="1" Text="{Binding CpuDelta}" TextAlignment="Right"
                                           Foreground="{DynamicResource Brush.Success}" IsVisible="{Binding !IsIncrease}" />
                                <TextBlock Grid.Column="2" Text="{Binding LongTaskDelta}" TextAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="{Binding HeapDelta}" TextAlignment="Right" />
                                <TextBlock Grid.Column="4" Text="{Binding Verdict}" TextAlignment="Right" />
                                <TextBlock Grid.Column="5" Text="{Binding Badge}" TextAlignment="Right" Classes="label" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 差分メトリクス表 -->
                        <Grid ColumnDefinitions="190,90,90,90,80" Margin="0,6,0,0">
                          <TextBlock Grid.Column="0" Classes="label" Text="指標" />
                          <TextBlock Grid.Column="1" Classes="label" Text="OFF" TextAlignment="Right" />
                          <TextBlock Grid.Column="2" Classes="label" Text="ON" TextAlignment="Right" />
                          <TextBlock Grid.Column="3" Classes="label" Text="Δ" TextAlignment="Right" />
                          <TextBlock Grid.Column="4" Classes="label" Text="判定" TextAlignment="Right" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Metrics}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MetricRowViewModel">
                              <Grid ColumnDefinitions="190,90,90,90,80" Margin="0,1">
                                <TextBlock Grid.Column="0" Text="{Binding Label}" />
                                <TextBlock Grid.Column="1" Text="{Binding Off}" TextAlignment="Right" />
                                <TextBlock Grid.Column="2" Text="{Binding On}" TextAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="{Binding Delta}" TextAlignment="Right"
                                           Foreground="{DynamicResource Brush.Danger}"
                                           IsVisible="{Binding IsIncrease}" />
                                <TextBlock Grid.Column="3" Text="{Binding Delta}" TextAlignment="Right"
                                           Foreground="{DynamicResource Brush.Success}"
                                           IsVisible="{Binding !IsIncrease}" />
                                <TextBlock Grid.Column="4" Text="{Binding Badge}" TextAlignment="Right" Classes="label" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding ExtensionCpuSummary}" Classes="label" Margin="0,6,0,0" />

                        <!-- Hot functions Top 10 -->
                        <Grid ColumnDefinitions="30,*,240,110,70,70" Margin="0,6,0,0">
                          <TextBlock Grid.Column="0" Classes="label" Text="#" />
                          <TextBlock Grid.Column="1" Classes="label" Text="関数" />
                          <TextBlock Grid.Column="2" Classes="label" Text="場所" />
                          <TextBlock Grid.Column="3" Classes="label" Text="実行元" />
                          <TextBlock Grid.Column="4" Classes="label" Text="Self ms" TextAlignment="Right" />
                          <TextBlock Grid.Column="5" Classes="label" Text="Total ms" TextAlignment="Right" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding HotFunctions}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HotFunctionRowViewModel">
                              <Grid ColumnDefinitions="30,*,240,110,70,70" Margin="0,1">
                                <TextBlock Grid.Column="0" Text="{Binding Rank}" Classes="label" />
                                <TextBlock Grid.Column="1" Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding Location}" Classes="label" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" Text="{Binding Origin}" Classes="label" />
                                <TextBlock Grid.Column="4" Text="{Binding SelfMs}" TextAlignment="Right" />
                                <TextBlock Grid.Column="5" Text="{Binding TotalMs}" TextAlignment="Right" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </TabItem>

        <!--  ━━━ 設定タブ ━━━  -->
        <TabItem Header="設定">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,0" MaxWidth="720" HorizontalAlignment="Left">
              <TextBlock Classes="h1" Text="設定" />

              <primitives:HeaderedContentControl Header="Chrome">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             PlaceholderText="chrome.exe のパス（空欄で自動検出）"
                             Text="{Binding Settings.ChromePath}" />
                    <Button Grid.Column="1" Content="参照..." Margin="8,0,0,0"
                            Command="{Binding Settings.BrowseChromeCommand}" />
                  </Grid>
                  <TextBlock Text="{Binding Settings.DetectedChromeText}" Classes="label" TextWrapping="Wrap" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="計測既定値">
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" PlaceholderText="出力フォルダ" Text="{Binding Settings.OutputRoot}" />
                    <Button Grid.Column="1" Content="参照..." Margin="8,0,0,0"
                            Command="{Binding Settings.BrowseOutputRootCommand}" />
                  </Grid>
                  <StackPanel Orientation="Horizontal" Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Classes="label" Text="既定の繰り返し回数" />
                      <NumericUpDown Value="{Binding Settings.DefaultRepeat}"
                                     Minimum="1" Maximum="9" Increment="1" FormatString="0" Width="100" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Classes="label" Text="既定のシナリオ長 (秒)" />
                      <NumericUpDown Value="{Binding Settings.DefaultDurationSec}"
                                     Minimum="10" Maximum="600" Increment="5" FormatString="0" Width="110" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="メンテナンス">
                <Button Content="📁 ログフォルダを開く" HorizontalAlignment="Left"
                        Command="{Binding Settings.OpenLogFolderCommand}" />
              </primitives:HeaderedContentControl>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!--  ━━━ 使い方タブ ━━━  -->
        <TabItem Header="使い方">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,0" MaxWidth="860" HorizontalAlignment="Left">
              <TextBlock Classes="h1" Text="使い方" />

              <primitives:HeaderedContentControl Header="このアプリでできること">
                <StackPanel Spacing="8">
                  <TextBlock TextWrapping="Wrap"
                             Text="ExtWeigh は、Chrome 拡張機能がブラウジングをどれだけ重くしているか（オーバーヘッド）を数値で示すツールです。" />
                  <TextBlock TextWrapping="Wrap"
                             Text="同じページを「全拡張 OFF」「全拡張 ON」「1つずつ OFF」で開いて差分を見ます。全ONとBだけOFFの差から、他の拡張と共存している条件でのBの寄与が分かります。計測にはクリーンな使い捨てプロファイルの Chrome を使うので、普段の Chrome には影響しません。" />
                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="対応: Manifest V3 の拡張機能（フォルダ形式・未パッケージ）。ログインが必要なページの計測は現在未対応です。" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="計測の流れ（5 ステップ）">
                <StackPanel Spacing="10">
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="① 拡張フォルダを選ぶ" />
                    <TextBlock Classes="label" TextWrapping="Wrap"
                               Text="「計測」タブで、manifest.json が直下にあるフォルダを指定します。開発中の拡張ならソースのルート、ストアの拡張なら展開済みフォルダです。" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="② 再現したい使い方を確認・調整する" />
                    <TextBlock Classes="label" TextWrapping="Wrap"
                               Text="拡張の対象サイトから候補が自動生成されます。普段重く感じるページのURLに置き換え、「この条件で行うこと」を確認してください。通常はページを開いて待機・スクロールを行い、ショートカットがある拡張ではそのキーを押してから待機します。" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="③ 繰り返し回数を決める" />
                    <TextBlock Classes="label" TextWrapping="Wrap"
                               Text="お試しなら 1 回で十分ですが、きちんと判断したいときは 3 回以上にしてください。サイトの表示内容や通信状態で計測値は毎回ブレます。複数回計測すると中央値で比較し、差が本物か誤差かを SIGNIF / NOISE で自動判定します。" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="④ 計測開始を押して待つ" />
                    <TextBlock Classes="label" TextWrapping="Wrap"
                               Text="Chrome が画面外で自動的に起動・終了を繰り返します。進み具合はログに表示されます。計測中は PC で重い作業（ビルド・動画など）を避けると精度が上がります。途中でやめたいときは「停止」を押してください。" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="⑤ 結果を読む" />
                    <TextBlock Classes="label" TextWrapping="Wrap"
                               Text="完了すると「結果」タブに自動で切り替わります。詳しい読み方は次のセクションをご覧ください。" />
                  </StackPanel>
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="結果の読み方">
                <StackPanel Spacing="8">
                  <TextBlock TextWrapping="Wrap"
                             Text="シナリオごとに全OFF / 全ONの差と、各拡張を1つだけ外したときの差が表示されます。拡張別のCPU寄与がプラス（赤）なら、その拡張が共存環境を重くしています。" />
                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="・CPU 合計 — ページ処理に使われた CPU 時間。いちばん基本の指標です&#x0a;・Long Tasks — メインスレッドを 50ms 以上ふさいだ処理の回数。多いほど「カクつき」の原因になります&#x0a;・JS ヒープ — JavaScript のメモリ使用量" />
                  <TextBlock TextWrapping="Wrap"
                             Text="判定バッジは差の信頼性を示します。SIGNIF なら統計的に意味のある差、NOISE なら誤差の範囲内なので気にする必要はありません。「-」は繰り返し 1 回のため判定できない状態です。" />
                  <TextBlock TextWrapping="Wrap"
                             Text="「hot functions」は拡張のコードの中で特に CPU を使った関数の一覧です。Self は関数自身の実行時間、Total は呼び出し先も含めた時間。ファイル名と行番号付きなので、そのまま最適化の着手点になります。実行元列で content script（page）か Service Worker かも分かります。" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="出力ファイルと flamegraph">
                <StackPanel Spacing="8">
                  <TextBlock TextWrapping="Wrap"
                             Text="計測データは出力フォルダ（既定: ドキュメント\ExtWeigh）にすべて保存されます。「結果」タブの「🌐 レポートを開く」で共有しやすい HTML レポートを開けます。" />
                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="・report.html — 全体差分・拡張別寄与・hot functionsのレポート&#x0a;・scenarios\…\all-on-1.cpuprofile — 全ONのV8 CPUプロファイル（単体時はon-1）&#x0a;・scenarios\…\without-&lt;拡張キー&gt;-1.* — その拡張だけOFFの生データ&#x0a;・*.trace.json — Chrome trace。Perfetto / chrome://tracing で開けます" />
                </StackPanel>
              </primitives:HeaderedContentControl>

              <primitives:HeaderedContentControl Header="うまくいかないとき">
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" TextWrapping="Wrap"
                             Text="・「chrome.exe が見つかりません」 → 「設定」タブで Chrome のパスを手動指定してください&#x0a;・拡張由来の CPU がいつも 0 → お使いの Chrome が拡張の自動読み込み (--load-extension) を無視している可能性があります。Chrome for Testing を入手して「設定」タブでそのパスを指定してください&#x0a;・「manifest_version が 2」と出る → MV2 拡張は非対応です。MV3 に移行したものを計測してください&#x0a;・計測値が毎回大きく違う → 繰り返し回数を 3 以上にして、SIGNIF バッジの付いた指標だけを信頼してください&#x0a;・詳しい動作ログ → 「設定」タブの「📁 ログフォルダを開く」から確認できます" />
                </StackPanel>
              </primitives:HeaderedContentControl>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

      </TabControl>
    </Grid>
  </Panel>
</Window>
